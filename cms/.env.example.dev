# Read about configuration, here:
# https://craftcms.com/docs/5.x/configure.html

# The application ID used to to uniquely store session and cache data, mutex locks, and more
CRAFT_APP_ID=

# The environment Craft is currently running in (dev, staging, production, etc.)
CRAFT_ENVIRONMENT=dev

# General settings
CRAFT_SECURITY_KEY=
CRAFT_DEV_MODE=true
CRAFT_ALLOW_ADMIN_CHANGES=true
CRAFT_DISALLOW_ROBOTS=true

# Next.js frontend URL (used for preview targets)
# Local dev tradeoff:
#   HTTP: webhooks work, preview broken (mixed content)
#   HTTPS: preview works, webhooks broken (self-signed cert rejected by DDEV)
# Production: both work with valid HTTPS certs
PRIMARY_SITE_URL="http://localhost:3000"

# Cache revalidation webhook (shared secret must match site/.env.local)
REVALIDATION_SECRET=
REVALIDATION_URL=http://host.docker.internal:3000/api/revalidate

# CRAFT_WEB_ROOT AND DB DETAILS ARE IN .ddev/.env.web
