# Craft CMS GraphQL endpoint (use HTTP for local DDEV — Node rejects self-signed certs)
CRAFT_URL="http://your-craft-site.ddev.site"

# Private schema token for preview/drafts (from Craft CP → Settings → GraphQL)
CRAFT_PREVIEW_TOKEN=""

# Shared secret for webhook validation (must match cms/.env)
REVALIDATION_SECRET=""
